{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/api/app" },
    { "source": "/calendar", "destination": "/api/app" },
    { "source": "/privacy", "destination": "/api/privacy" },
    { "source": "/terms", "destination": "/api/terms" }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 1 * * *"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
