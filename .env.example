# ចម្លងទៅ .env (local) ឬ Vercel Environment Variables — កុំ commit ដាក់ .env ពិត

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Google OAuth (Google Cloud Console → Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://<your-app>.vercel.app/api/oauth/callback

# --- Supabase (Settings → API) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Secrets (បង្កើតដោយ `node scripts/gen-secrets.js`) ---
ENCRYPTION_KEY=
STATE_SECRET=
CRON_SECRET=

# --- Admin / Mini App (ស្រេចចិត្ត) ---
ADMIN_TELEGRAM_ID=
ADMIN_EMAIL=
PUBLIC_BASE_URL=https://<your-app>.vercel.app

# --- ព័ត៌មានទំនាក់ទំនង/branding (ស្រេចចិត្ត) ---
REANKH_URL=https://reankh.org
SUPPORT_EMAIL=support@reankh.org
BRAND_NAME=Telegram Calendar

# --- Default settings (ស្រេចចិត្ត) ---
DEFAULT_TIMEZONE=Asia/Phnom_Penh
DEFAULT_REMINDER_MINUTES=30
KH_LUNAR_OFFSET_DAYS=0
